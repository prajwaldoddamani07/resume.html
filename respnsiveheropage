<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Responsive Landing Section</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f5f5f5;
    }

    /* Landing Section */
    .landing {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      min-height: 100vh;
      background: linear-gradient(to right, #667eea, #764ba2);
      color: white;
      text-align: center;
    }

    .content {
      max-width: 500px;
    }

    .content h1 {
      font-size: 2rem;
      margin-bottom: 15px;
    }

    .content p {
      font-size: 1rem;
      margin-bottom: 20px;
    }

    .btn {
      display: inline-block;
      padding: 12px 25px;
      background: #fff;
      color: #333;
      text-decoration: none;
      border-radius: 25px;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn:hover {
      background: #ddd;
    }

    .image {
      margin-top: 30px;
    }

    .image img {
      width: 100%;
      max-width: 400px;
    }

    /* Tablet & Desktop */
    @media (min-width: 768px) {
      .landing {
        flex-direction: row;
        text-align: left;
        padding: 60px;
      }

      .content {
        flex: 1;
        padding-right: 30px;
      }

      .image {
        flex: 1;
        margin-top: 0;
      }
    }
  </style>
</head>

<body>

  <section class="landing">
    
    <div class="content">
      <h1>Welcome to My Website</h1>
      <p>Build modern and responsive websites using Flexbox. Easy, fast, and powerful.</p>
      <a href="#" class="btn">Get Started</a>
    </div>

    <div class="image">
      <img src="https://via.placeholder.com/400" alt="Landing Image">
    </div>

  </section>

</body>
</html>
